[project]
name = "{{ project_name }}"
version = "0.1.0"
description = ""
requires-python = ">=3.10"
dependencies = [
    "databricks-sdk",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.ruff]
target-version = "py310"
line-length = 99

[tool.ruff.lint]
select = ["E", "F", "I", "UP"]

[tool.pytest.ini_options]
testpaths = ["tests"]
