from unittest.mock import MagicMock, patch


def test_agent_predict_returns_assistant_message():
    """Smoke test: Agent.predict() returns a well-formed assistant message."""
    mock_response = MagicMock()
    mock_response.choices[0].message.content = "test response"

    mock_client = MagicMock()
    mock_client.serving_endpoints.query.return_value = mock_response

    from {{ project_name }}.agent import Agent

    agent = Agent()
    # Bypass load_context by injecting dependencies directly.
    agent._endpoint = "test-endpoint"
    agent._client = mock_client

    result = agent.predict(
        context=MagicMock(),
        model_input={"messages": [{"role": "user", "content": "hello"}]},
    )

    assert result["role"] == "assistant"
    assert result["content"] == "test response"
    mock_client.serving_endpoints.query.assert_called_once()
