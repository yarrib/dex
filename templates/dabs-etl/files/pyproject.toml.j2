[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "DLT ETL pipeline"
requires-python = ">={{ python_version }}"
dependencies = [
    "databricks-sdk",
    "pyspark",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[dependency-groups]
dev = [
    "pytest>=8.0",
    "ruff>=0.4",
    "databricks-connect",
]

[tool.uv]
python-version = "{{ python_version }}"

[tool.ruff]
target-version = "py{{ python_version | replace('.', '') }}"
line-length = 99

[tool.ruff.lint]
select = ["E", "F", "I", "UP"]

[tool.pytest.ini_options]
testpaths = ["tests"]
